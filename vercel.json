{
  "version": 2,
  "builds": [
    { "src": "api/proxy.js", "use": "@vercel/node" },
    { "src": "api/nexa.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/proxy(.*)", "dest": "/api/proxy.js" },
    { "src": "/api/nexa(.*)", "dest": "/api/nexa.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
